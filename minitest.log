+++ b/outputs/train.py
@@ -0,0 +1,101 @@
+#!/usr/bin/env python3
+import argparse
+from pathlib import Path
+
+import numpy as np
+import torch
+from torch.utils.data import DataLoader
+
+from common import FeatureExtractor, ImageDataset, anomaly_map
+
+
+def parse_args():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--train-dir", default="./data/train")
+    parser.add_argument("--model-out", default="./outputs/model.pt")
+    parser.add_argument("--batch-size", type=int, default=8)
+    parser.add_argument("--num-workers", type=int, default=4)
+    parser.add_argument("--feature-channels", type=int, default=256)
+    parser.add_argument("--seed", type=int, default=17)
+    parser.add_argument("--device", default="cuda" if torch.cuda.is_available() else "cpu")
+    return parser.parse_args()
+
+
+def make_loader(dataset, args):
+    return DataLoader(
+        dataset,
+        batch_size=args.batch_size,
+        shuffle=False,
+        num_workers=args.num_workers,
+        pin_memory=args.device.startswith("cuda"),
+    )
+
+
+def main():
+    args = parse_args()
+    torch.manual_seed(args.seed)
+    np.random.seed(args.seed)
+
+    dataset = ImageDataset(args.train_dir)
+    loader = make_loader(dataset, args)
+    total_channels = sum(FeatureExtractor.CHANNELS)
+    if not 1 <= args.feature_channels <= total_channels:
+        raise ValueError(f"feature-channels must be between 1 and {total_channels}")
+    selected = np.sort(
+        np.random.default_rng(args.seed).choice(
+            total_channels, size=args.feature_channels, replace=False
+        )
+    )
+
+    device = torch.device(args.device)
+    extractor = FeatureExtractor(selected).to(device)
+    sums = torch.zeros(
+        args.feature_channels, 64, 64, dtype=torch.float64, device=device
+    )
+    squared_sums = torch.zeros_like(sums)
+    count = 0
+
+    print(f"Fitting feature statistics on {len(dataset)} images using {device}...")
+    with torch.inference_mode():
+        for images, _ in loader:
+            features = extractor(images.to(device, non_blocking=True)).double()
+            sums += features.sum(dim=0)
+            squared_sums += features.square().sum(dim=0)
+            count += features.shape[0]
+
+    mean = sums / count
+    variance = (squared_sums / count - mean.square()).clamp_min(0.0) + 0.01
+    mean = mean.float()
+    variance = variance.float()
+
+    # Calibrate PNG intensities against normal training-map values.
+    calibration_values = []
+    with torch.inference_mode():
+        for images, _ in loader:
+            features = extractor(images.to(device, non_blocking=True))
+            maps = anomaly_map(features, mean, variance)
+            calibration_values.append(maps.cpu().flatten())
+    calibration_values = torch.cat(calibration_values)
+    map_scale = float(torch.quantile(calibration_values, 0.995).item())
+
+    model_out = Path(args.model_out)
+    model_out.parent.mkdir(parents=True, exist_ok=True)
+    torch.save(
+        {
+            "method": "spatial_diagonal_gaussian",
+            "backbone": "wide_resnet50_2_imagenet1k_v2",
+            "selected_channels": torch.from_numpy(selected),
+            "mean": mean.cpu(),
+            "variance": variance.cpu(),
+            "map_scale": map_scale,
+            "image_size": 256,
+            "feature_size": 64,
+            "top_fraction": 0.01,
+        },
+        model_out,
+    )
+    print(f"Saved model to {model_out} (normal-map 99.5th percentile={map_scale:.6f})")
+
+
+if __name__ == "__main__":
+    main()

