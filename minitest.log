+#!/usr/bin/env python3
+import argparse
+import math
+from pathlib import Path
+
+import torch
+import torch.nn.functional as F
+from PIL import Image
+from torch.utils.data import DataLoader, Dataset
+from torchvision.models import Wide_ResNet50_2_Weights, wide_resnet50_2
+from torchvision.transforms import InterpolationMode
+from torchvision.transforms.functional import normalize, pil_to_tensor, resize
+
+
+IMAGE_SUFFIXES = {".png", ".jpg", ".jpeg", ".bmp", ".tif", ".tiff", ".webp"}
+CHANNEL_COUNTS = (64, 96, 96)
+
+
+def image_files(directory: Path) -> list[Path]:
+    return sorted(
+        p for p in directory.iterdir()
+        if p.is_file() and p.suffix.lower() in IMAGE_SUFFIXES
+    )
+
+
+class ImageDataset(Dataset):
+    def __init__(self, directory: Path):
+        self.files = image_files(directory)
+        if not self.files:
+            raise RuntimeError(f"No images found in {directory}")
+
+    def __len__(self):
+        return len(self.files)
+
+    def __getitem__(self, index):
+        with Image.open(self.files[index]) as image:
+            image = image.convert("RGB")
+            tensor = resize(
+                pil_to_tensor(image),
+                [256, 256],
+                interpolation=InterpolationMode.BILINEAR,
+                antialias=True,
+            ).float().div_(255.0)
+        return normalize(
+            tensor,
+            mean=[0.485, 0.456, 0.406],
+            std=[0.229, 0.224, 0.225],
+        )
+
+
+class FeatureExtractor(torch.nn.Module):
+    def __init__(self):
+        super().__init__()
+        model = wide_resnet50_2(weights=Wide_ResNet50_2_Weights.IMAGENET1K_V2)
+        self.stem = torch.nn.Sequential(
+            model.conv1, model.bn1, model.relu, model.maxpool
+        )
+        self.layer1 = model.layer1
+        self.layer2 = model.layer2
+        self.layer3 = model.layer3
+
+    def forward(self, x):
+        x = self.stem(x)
+        f1 = self.layer1(x)
+        f2 = self.layer2(f1)
+        f3 = self.layer3(f2)
+        return f1, f2, f3
+
+
+def selected_indices(channels: int, count: int) -> torch.Tensor:
+    # Even spacing gives deterministic coverage across every feature stage.
+    return torch.linspace(0, channels - 1, count).round().long().unique()
+
+
+def combine_features(features, indices):
+    selected = []
+    for feature, index in zip(features, indices):
+        feature = feature.index_select(1, index)
+        if feature.shape[-2:] != (64, 64):
+            feature = F.interpolate(
+                feature, size=(64, 64), mode="bilinear", align_corners=False
+            )
+        selected.append(feature)
+    return torch.cat(selected, dim=1)
+
+
+def main():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--train-dir", type=Path, default=Path("data/train"))
+    parser.add_argument("--model-out", type=Path, default=Path("outputs/model.pt"))
+    parser.add_argument("--batch-size", type=int, default=8)
+    parser.add_argument("--num-workers", type=int, default=4)
+    parser.add_argument("--device", default="cuda" if torch.cuda.is_available() else "cpu")
+    args = parser.parse_args()
+
+    device = torch.device(args.device)
+    dataset = ImageDataset(args.train_dir)
+    loader = DataLoader(
+        dataset,
+        batch_size=args.batch_size,
+        shuffle=False,
+        num_workers=args.num_workers,
+        pin_memory=device.type == "cuda",
+    )
+    extractor = FeatureExtractor().to(device).eval()
+    stage_channels = (256, 512, 1024)
+    indices = [
+        selected_indices(channels, count).to(device)
+        for channels, count in zip(stage_channels, CHANNEL_COUNTS)
+    ]
+
+    feature_sum = None
+    feature_sq_sum = None
+    count = 0
+    with torch.inference_mode():
+        for images in loader:
+            images = images.to(device, non_blocking=True)
+            features = combine_features(extractor(images), indices).double()
+            batch_sum = features.sum(dim=0).cpu()
+            batch_sq_sum = features.square().sum(dim=0).cpu()
+            feature_sum = batch_sum if feature_sum is None else feature_sum + batch_sum
+            feature_sq_sum = (
+                batch_sq_sum if feature_sq_sum is None
+                else feature_sq_sum + batch_sq_sum
+            )
+            count += images.shape[0]
+
+    mean = feature_sum / count
+    variance = (feature_sq_sum / count - mean.square()).clamp_min_(1e-4)
+    args.model_out.parent.mkdir(parents=True, exist_ok=True)
+    torch.save(
+        {
+            "method": "PaDiM-style spatial diagonal Gaussian",
+            "backbone": "wide_resnet50_2_imagenet1k_v2",
+            "image_size": 256,
+            "feature_size": 64,
+            "channel_indices": [index.cpu() for index in indices],
+            "mean": mean.float(),
+            "inv_std": variance.rsqrt().float(),
+            "train_image_count": count,
+        },
+        args.model_out,
+    )
+    print(f"Saved model trained on {count} images to {args.model_out}")
+
+
+if __name__ == "__main__":
+    main()

