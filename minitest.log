@@ -0,0 +1,139 @@
+from pathlib import Path
+
+import torch
+import torch.nn.functional as F
+from PIL import Image
+from torch import nn
+from torchvision.models import ResNet18_Weights, resnet18
+
+
+# Shared configuration
+IMAGE_SIZE = 256
+FEATURE_LAYERS = ("layer1", "layer2", "layer3")
+FEATURE_SIZE = 64
+GAUSSIAN_SIGMA = 1.5
+VARIANCE_FLOOR = 1e-4
+TOP_FRACTION = 0.01
+IMAGE_EXTENSIONS = {".png", ".jpg", ".jpeg", ".bmp", ".tif", ".tiff", ".webp"}
+
+_MEAN = torch.tensor([0.485, 0.456, 0.406]).view(3, 1, 1)
+_STD = torch.tensor([0.229, 0.224, 0.225]).view(3, 1, 1)
+
+
+def image_paths(directory: Path) -> list[Path]:
+    return sorted(
+        path for path in directory.iterdir()
+        if path.is_file() and path.suffix.lower() in IMAGE_EXTENSIONS
+    )
+
+
+def load_image(path: Path) -> torch.Tensor:
+    image = Image.open(path).convert("RGB").resize(
+        (IMAGE_SIZE, IMAGE_SIZE), Image.Resampling.BILINEAR
+    )
+    array = torch.frombuffer(bytearray(image.tobytes()), dtype=torch.uint8)
+    tensor = array.reshape(IMAGE_SIZE, IMAGE_SIZE, 3).permute(2, 0, 1).float() / 255.0
+    return (tensor - _MEAN) / _STD
+
+
+class FeatureExtractor(nn.Module):
+    """Frozen ImageNet ResNet-18 returning normalized multi-depth feature maps."""
+
+    def __init__(self) -> None:
+        super().__init__()
+        network = resnet18(weights=ResNet18_Weights.IMAGENET1K_V1)
+        self.stem = nn.Sequential(
+            network.conv1, network.bn1, network.relu, network.maxpool
+        )
+        self.layer1 = network.layer1
+        self.layer2 = network.layer2
+        self.layer3 = network.layer3
+        self.eval()
+        for parameter in self.parameters():
+            parameter.requires_grad_(False)
+
+    def forward(self, images: torch.Tensor) -> torch.Tensor:
+        x = self.stem(images)
+        features = []
+        for layer in (self.layer1, self.layer2, self.layer3):
+            x = layer(x)
+            feature = F.normalize(x, p=2, dim=1)
+            if feature.shape[-2:] != (FEATURE_SIZE, FEATURE_SIZE):
+                feature = F.interpolate(
+                    feature,
+                    size=(FEATURE_SIZE, FEATURE_SIZE),
+                    mode="bilinear",
+                    align_corners=False,
+                )
+            features.append(feature)
+        return torch.cat(features, dim=1)
+
+
+def extract_features(
+    extractor: FeatureExtractor, images: torch.Tensor
+) -> torch.Tensor:
+    with torch.inference_mode():
+        return extractor(images)
+
+
+def fit_normal_model(
+    extractor: FeatureExtractor,
+    paths: list[Path],
+    device: torch.device,
+    batch_size: int,
+) -> dict[str, torch.Tensor]:
+    feature_sum = None
+    feature_square_sum = None
+    count = 0
+
+    for start in range(0, len(paths), batch_size):
+        batch = torch.stack([load_image(path) for path in paths[start:start + batch_size]])
+        features = extract_features(extractor, batch.to(device))
+        current_sum = features.sum(dim=0, dtype=torch.float64)
+        current_square_sum = features.square().sum(dim=0, dtype=torch.float64)
+        feature_sum = current_sum if feature_sum is None else feature_sum + current_sum
+        feature_square_sum = (
+            current_square_sum
+            if feature_square_sum is None
+            else feature_square_sum + current_square_sum
+        )
+        count += features.shape[0]
+
+    mean = feature_sum / count
+    variance = feature_square_sum / count - mean.square()
+    return {
+        "mean": mean.float().cpu(),
+        "variance": variance.clamp_min(VARIANCE_FLOOR).float().cpu(),
+    }
+
+
+def gaussian_kernel(sigma: float, device: torch.device) -> torch.Tensor:
+    radius = max(1, int(3.0 * sigma + 0.5))
+    coordinates = torch.arange(-radius, radius + 1, device=device, dtype=torch.float32)
+    kernel_1d = torch.exp(-(coordinates.square()) / (2.0 * sigma * sigma))
+    kernel_1d /= kernel_1d.sum()
+    return torch.outer(kernel_1d, kernel_1d)[None, None]
+
+
+def score_features(
+    features: torch.Tensor,
+    mean: torch.Tensor,
+    variance: torch.Tensor,
+) -> torch.Tensor:
+    standardized_error = (features - mean).square() / variance
+    maps = standardized_error.mean(dim=1, keepdim=True).sqrt()
+    kernel = gaussian_kernel(GAUSSIAN_SIGMA, maps.device)
+    padding = kernel.shape[-1] // 2
+    return F.conv2d(maps, kernel, padding=padding).squeeze(1)
+
+
+def aggregate_image_scores(maps: torch.Tensor) -> torch.Tensor:
+    flat = maps.flatten(1)
+    top_count = max(1, int(flat.shape[1] * TOP_FRACTION))
+    return flat.topk(top_count, dim=1).values.mean(dim=1)
+
+
+def normalize_image_score(raw_score: torch.Tensor, model: dict) -> torch.Tensor:
+    robust_z = (raw_score - model["score_median"]) / model["score_scale"]
+    return torch.sigmoid((robust_z - 3.0) / 1.5)
+
