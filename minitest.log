+    np.random.seed(0)
+    torch.manual_seed(0)
+    paths = image_files(args.train_dir)
+    if not paths:
+        raise RuntimeError(f"No training images found in {args.train_dir}")
+
+    device = torch.device(args.device)
+    extractor = FeatureExtractor().eval().to(device)
+    total = None
+    total_sq = None
+    count = 0
+
+    with torch.inference_mode():
+        for start in range(0, len(paths), args.batch_size):
+            features = extractor(load_batch(paths[start : start + args.batch_size], device))
+            batch_sum = features.double().sum(dim=0)
+            batch_sq = features.double().square().sum(dim=0)
+            total = batch_sum if total is None else total + batch_sum
+            total_sq = batch_sq if total_sq is None else total_sq + batch_sq
+            count += features.shape[0]
+
+        mean = (total / count).float()
+        variance = (total_sq / count - (total / count).square()).float()
+        # A floor prevents nearly constant background features from dominating.
+        channel_floor = torch.quantile(
+            variance.flatten(1), 0.10, dim=1
+        ).clamp_min(1e-4)[:, None, None]
+        variance = torch.maximum(variance, channel_floor)
+
+        calibration_samples = []
+        for start in range(0, len(paths), args.batch_size):
+            features = extractor(load_batch(paths[start : start + args.batch_size], device))
+            maps = anomaly_maps(features, mean, variance)
+            calibration_samples.append(maps.flatten().cpu())
+        calibration = torch.cat(calibration_samples)
+        pixel_low = float(torch.quantile(calibration, 0.95))
+        pixel_high = float(torch.quantile(calibration, 0.999))
+
+    args.output.parent.mkdir(parents=True, exist_ok=True)
+    torch.save(
+        {
+            "mean": mean.cpu(),
+            "variance": variance.cpu(),
+            "pixel_low": pixel_low,
+            "pixel_high": max(pixel_high, pixel_low + 1e-6),
+            "method": "diagonal positional Gaussian multi-scale features",
+            "backbone": "ImageNet ResNet-18",
+            "num_train_images": len(paths),
+        },
+        args.output,
+    )
+    print(f"Trained on {len(paths)} normal images; saved {args.output}")
+
+
+if __name__ == "__main__":
+    main()

