@@ -0,0 +1,201 @@
+from __future__ import annotations
+
+import random
+from pathlib import Path
+
+import numpy as np
+import torch
+import torch.nn.functional as F
+from PIL import Image
+from torch import nn
+from torch.utils.data import DataLoader, Dataset
+from torchvision.models import Wide_ResNet50_2_Weights, wide_resnet50_2
+from torchvision.transforms import InterpolationMode
+from torchvision.transforms import functional as TF
+
+import config
+
+
+def set_deterministic(seed: int) -> None:
+    random.seed(seed)
+    np.random.seed(seed)
+    torch.manual_seed(seed)
+    if torch.cuda.is_available():
+        torch.cuda.manual_seed_all(seed)
+
+
+def image_files(directory: Path) -> list[Path]:
+    return sorted(
+        path
+        for path in directory.iterdir()
+        if path.is_file() and path.suffix.lower() in config.IMAGE_EXTENSIONS
+    )
+
+
+class ImageDataset(Dataset):
+    def __init__(self, files: list[Path]) -> None:
+        self.files = files
+        self.mean = [0.485, 0.456, 0.406]
+        self.std = [0.229, 0.224, 0.225]
+
+    def __len__(self) -> int:
+        return len(self.files)
+
+    def __getitem__(self, index: int) -> tuple[torch.Tensor, str]:
+        path = self.files[index]
+        with Image.open(path) as image:
+            image = image.convert("RGB")
+            image = TF.resize(
+                image,
+                [config.IMAGE_SIZE, config.IMAGE_SIZE],
+                interpolation=InterpolationMode.BILINEAR,
+                antialias=True,
+            )
+            tensor = TF.to_tensor(image)
+        return TF.normalize(tensor, self.mean, self.std), path.name
+
+
+class FeatureExtractor(nn.Module):
+    """ImageNet backbone exposing two mid-level feature maps."""
+
+    def __init__(self) -> None:
+        super().__init__()
+        model = wide_resnet50_2(weights=Wide_ResNet50_2_Weights.IMAGENET1K_V2)
+        self.stem = nn.Sequential(model.conv1, model.bn1, model.relu, model.maxpool)
+        self.layer1 = model.layer1
+        self.layer2 = model.layer2
+        self.layer3 = model.layer3
+        for parameter in self.parameters():
+            parameter.requires_grad_(False)
+
+    def forward(self, images: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor]:
+        x = self.layer1(self.stem(images))
+        level2 = self.layer2(x)
+        level3 = self.layer3(level2)
+        return level2, level3
+
+
+def extract_features(
+    extractor: FeatureExtractor,
+    images: torch.Tensor,
+    projection: torch.Tensor,
+) -> torch.Tensor:
+    """Return a B x H x W x D concatenated, projected patch embedding grid."""
+    level2, level3 = extractor(images)
+    level2 = F.adaptive_avg_pool2d(level2, (config.FEATURE_GRID, config.FEATURE_GRID))
+    level3 = F.interpolate(
+        level3,
+        size=(config.FEATURE_GRID, config.FEATURE_GRID),
+        mode="bilinear",
+        align_corners=False,
+    )
+    features = torch.cat([level2, level3], dim=1)
+    features = features.permute(0, 2, 3, 1)
+    features = features @ projection
+    return F.normalize(features, dim=-1)
+
+
+def make_projection(input_dim: int, output_dim: int, device: torch.device) -> torch.Tensor:
+    generator = torch.Generator(device=device).manual_seed(config.SEED)
+    projection = torch.randn(input_dim, output_dim, generator=generator, device=device)
+    return projection / np.sqrt(output_dim)
+
+
+def build_normal_model(
+    extractor: FeatureExtractor,
+    loader: DataLoader,
+    device: torch.device,
+) -> tuple[torch.Tensor, torch.Tensor, list[torch.Tensor]]:
+    """Extract normal patches and store a deterministic random memory subset."""
+    projection = make_projection(1536, config.PROJECTION_DIM, device)
+    image_grids: list[torch.Tensor] = []
+    with torch.inference_mode():
+        for images, _ in loader:
+            grids = extract_features(extractor, images.to(device), projection)
+            image_grids.extend(grid.cpu() for grid in grids)
+
+    all_patches = torch.cat([grid.reshape(-1, config.PROJECTION_DIM) for grid in image_grids])
+    generator = torch.Generator().manual_seed(config.SEED)
+    count = min(config.MEMORY_BANK_SIZE, len(all_patches))
+    indices = torch.randperm(len(all_patches), generator=generator)[:count]
+    memory_bank = all_patches[indices].contiguous()
+    return projection.cpu(), memory_bank, image_grids
+
+
+def nearest_patch_distances(
+    patches: torch.Tensor,
+    memory_bank: torch.Tensor,
+) -> torch.Tensor:
+    """Compute exact nearest-neighbor Euclidean distance in bounded chunks."""
+    minima = []
+    for start in range(0, len(memory_bank), config.DISTANCE_CHUNK_SIZE):
+        bank_chunk = memory_bank[start : start + config.DISTANCE_CHUNK_SIZE]
+        minima.append(torch.cdist(patches, bank_chunk).amin(dim=1))
+    return torch.stack(minima, dim=0).amin(dim=0)
+
+
+def smooth_and_resize(patch_map: torch.Tensor) -> torch.Tensor:
+    patch_map = patch_map[None, None]
+    patch_map = TF.gaussian_blur(
+        patch_map,
+        kernel_size=[config.GAUSSIAN_KERNEL_SIZE, config.GAUSSIAN_KERNEL_SIZE],
+        sigma=[config.GAUSSIAN_SIGMA, config.GAUSSIAN_SIGMA],
+    )
+    return F.interpolate(
+        patch_map,
+        size=(config.IMAGE_SIZE, config.IMAGE_SIZE),
+        mode="bilinear",
+        align_corners=False,
+    )[0, 0]
+
+
+def aggregate_image_score(anomaly_map: torch.Tensor) -> float:
+    count = max(1, int(anomaly_map.numel() * config.TOP_FRACTION))
+    return float(torch.topk(anomaly_map.flatten(), count).values.mean().item())
+
+
+def score_feature_grid(
+    feature_grid: torch.Tensor,
+    memory_bank: torch.Tensor,
+) -> tuple[torch.Tensor, float]:
+    distances = nearest_patch_distances(
+        feature_grid.reshape(-1, feature_grid.shape[-1]), memory_bank
+    )
+    patch_map = distances.reshape(config.FEATURE_GRID, config.FEATURE_GRID)
+    anomaly_map = smooth_and_resize(patch_map)
+    return anomaly_map, aggregate_image_score(anomaly_map)
+
+
+def fit_score_calibration(
+    image_grids: list[torch.Tensor],
+    memory_bank: torch.Tensor,
+    device: torch.device,
+) -> dict[str, float]:
+    """Estimate robust normal ranges without reading any test information."""
+    bank = memory_bank.to(device)
+    generator = torch.Generator().manual_seed(config.SEED)
+    indices = torch.randperm(len(image_grids), generator=generator)[
+        : min(config.CALIBRATION_IMAGES, len(image_grids))
+    ]
+    image_scores = []
+    pixel_values = []
+    with torch.inference_mode():
+        for index in indices.tolist():
+            anomaly_map, image_score = score_feature_grid(image_grids[index].to(device), bank)
+            image_scores.append(image_score)
+            pixel_values.append(anomaly_map.flatten().cpu())
+
+    scores = np.asarray(image_scores, dtype=np.float64)
+    pixels = torch.cat(pixel_values).numpy()
+    image_low, image_high = np.quantile(scores, [0.05, 0.995])
+    pixel_low, pixel_high = np.quantile(pixels, [0.05, 0.995])
+    return {
+        "image_low": float(image_low),
+        "image_high": float(max(image_high, image_low + 1e-6)),
+        "pixel_low": float(pixel_low),
+        "pixel_high": float(max(pixel_high, pixel_low + 1e-6)),
+    }
+
+
+def normalize_score(value: float, low: float, high: float) -> float:
+    return float(np.clip((value - low) / (high - low), 0.0, 1.0))
