+#!/usr/bin/env python3
+"""Score test images with a training-only PatchCore-style memory bank."""
+
+from __future__ import annotations
+
+import argparse
+import csv
+import json
+import random
+from pathlib import Path
+
+import numpy as np
+import torch
+import torch.nn.functional as F
+from PIL import Image
+from torch.utils.data import DataLoader, Dataset
+from torchvision.models import Wide_ResNet50_2_Weights, wide_resnet50_2
+
+
+IMAGE_SUFFIXES = {".png", ".jpg", ".jpeg", ".bmp", ".tif", ".tiff", ".webp"}
+
+
+def image_files(directory: Path) -> list[Path]:
+    return sorted(
+        path
+        for path in directory.iterdir()
+        if path.is_file() and path.suffix.lower() in IMAGE_SUFFIXES
+    )
+
+
+class ImageDataset(Dataset):
+    def __init__(self, paths: list[Path], transform):
+        self.paths = paths
+        self.transform = transform
+
+    def __len__(self) -> int:
+        return len(self.paths)
+
+    def __getitem__(self, index: int):
+        path = self.paths[index]
+        with Image.open(path) as image:
+            tensor = self.transform(image.convert("RGB"))
+        return tensor, path.name
+
+
+class PatchFeatureExtractor(torch.nn.Module):
+    def __init__(self):
+        super().__init__()
+        self.backbone = wide_resnet50_2(weights=Wide_ResNet50_2_Weights.DEFAULT)
+        self.backbone.eval()
+        for parameter in self.backbone.parameters():
+            parameter.requires_grad_(False)
+
+    def forward(self, images: torch.Tensor) -> torch.Tensor:
+        x = self.backbone.conv1(images)
+        x = self.backbone.bn1(x)
+        x = self.backbone.relu(x)
+        x = self.backbone.maxpool(x)
+        x = self.backbone.layer1(x)
+        layer2 = self.backbone.layer2(x)
+        layer3 = self.backbone.layer3(layer2)
+
+        layer2 = F.avg_pool2d(layer2, kernel_size=3, stride=1, padding=1)
+        layer3 = F.avg_pool2d(layer3, kernel_size=3, stride=1, padding=1)
+        layer3 = F.interpolate(
+            layer3, size=layer2.shape[-2:], mode="bilinear", align_corners=False
+        )
+        layer2 = F.normalize(layer2, dim=1)
+        layer3 = F.normalize(layer3, dim=1)
+        return torch.cat((layer2, layer3), dim=1)
+
+
+@torch.inference_mode()
+def extract_features(
+    model: torch.nn.Module,
+    loader: DataLoader,
+    device: torch.device,
+) -> tuple[torch.Tensor, list[str], tuple[int, int]]:
+    batches = []
+    names = []
+    spatial_shape = None
+    for images, batch_names in loader:
+        features = model(images.to(device, non_blocking=True))
+        spatial_shape = tuple(features.shape[-2:])
+        features = features.permute(0, 2, 3, 1).contiguous().cpu()
+        batches.append(features)
+        names.extend(batch_names)
+    if not batches or spatial_shape is None:
+        raise RuntimeError("No images were found")
+    return torch.cat(batches), names, spatial_shape
+
+
+def make_memory_bank(
+    train_features: torch.Tensor,
+    max_patches: int,
+    generator: torch.Generator,
+) -> torch.Tensor:
+    flat = train_features.reshape(-1, train_features.shape[-1])
+    if len(flat) <= max_patches:
+        return flat
+    indices = torch.randperm(len(flat), generator=generator)[:max_patches]
+    return flat[indices]
+
+
+@torch.inference_mode()
+def score_images(
+    test_features: torch.Tensor,
+    memory_bank: torch.Tensor,
+    device: torch.device,
+    query_chunk: int,
+    bank_chunk: int,
+    top_fraction: float,
+) -> list[float]:
+    bank_cpu = memory_bank.contiguous()
+    scores = []
+    for image_features in test_features:
+        queries = image_features.reshape(-1, image_features.shape[-1]).to(device)
+        minimum = torch.full(
+            (len(queries),), float("inf"), dtype=torch.float32, device=device
+        )
+        for bank_start in range(0, len(bank_cpu), bank_chunk):
+            bank = bank_cpu[bank_start : bank_start + bank_chunk].to(
+                device, non_blocking=True
+            )
+            for query_start in range(0, len(queries), query_chunk):
+                query = queries[query_start : query_start + query_chunk]
+                distances = torch.cdist(query, bank)
+                nearest = distances.min(dim=1).values
+                current = minimum[query_start : query_start + len(query)]
+                minimum[query_start : query_start + len(query)] = torch.minimum(
+                    current, nearest
+                )
+        top_k = max(1, round(len(minimum) * top_fraction))
+        # Combining the maximum and upper-tail mean is less sensitive to a
+        # single unstable patch while retaining small-defect sensitivity.
+        top_values = minimum.topk(top_k).values
+        score = 0.5 * minimum.max() + 0.5 * top_values.mean()
+        scores.append(float(score.cpu()))
+    return scores
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--train-dir", type=Path, default=Path("data/train"))
+    parser.add_argument("--test-dir", type=Path, default=Path("data/test_images"))
+    parser.add_argument("--output-csv", type=Path, default=Path("anomaly_scores.csv"))
+    parser.add_argument("--output-json", type=Path, default=Path("anomaly_scores.json"))
+    parser.add_argument("--batch-size", type=int, default=16)
+    parser.add_argument("--max-memory-patches", type=int, default=40000)
+    parser.add_argument("--query-chunk", type=int, default=256)
+    parser.add_argument("--bank-chunk", type=int, default=10000)
+    parser.add_argument("--top-fraction", type=float, default=0.01)
+    parser.add_argument("--seed", type=int, default=17)
+    args = parser.parse_args()
+
+    random.seed(args.seed)
+    np.random.seed(args.seed)
+    torch.manual_seed(args.seed)
+
+    train_paths = image_files(args.train_dir)
+    test_paths = image_files(args.test_dir)
+    if not train_paths:
+        raise RuntimeError(f"No training images in {args.train_dir}")
+    if not test_paths:
+        raise RuntimeError(f"No test images in {args.test_dir}")
+
+    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
+    weights = Wide_ResNet50_2_Weights.DEFAULT
+    transform = weights.transforms(crop_size=256, resize_size=256)
+    loader_options = {
+        "batch_size": args.batch_size,
+        "num_workers": 2,
+        "pin_memory": device.type == "cuda",
+        "shuffle": False,
+    }
+    train_loader = DataLoader(ImageDataset(train_paths, transform), **loader_options)
+    test_loader = DataLoader(ImageDataset(test_paths, transform), **loader_options)
+
+    model = PatchFeatureExtractor().to(device)
+    train_features, _, _ = extract_features(model, train_loader, device)
+    test_features, test_names, _ = extract_features(model, test_loader, device)
+    generator = torch.Generator().manual_seed(args.seed)
+    memory_bank = make_memory_bank(
+        train_features, args.max_memory_patches, generator
+    )
+    scores = score_images(
+        test_features,
+        memory_bank,
+        device,
+        args.query_chunk,
+        args.bank_chunk,
+        args.top_fraction,
+    )
+
+    rows = [
+        {"filename": name, "anomaly_score": score}
+        for name, score in zip(test_names, scores, strict=True)
+    ]
+    with args.output_csv.open("w", newline="", encoding="utf-8") as handle:
+        writer = csv.DictWriter(handle, fieldnames=["filename", "anomaly_score"])
+        writer.writeheader()
+        writer.writerows(rows)
+    with args.output_json.open("w", encoding="utf-8") as handle:
+        json.dump(rows, handle, indent=2)
+        handle.write("\n")
+
+    print(f"Scored {len(rows)} test images using {len(memory_bank)} memory patches.")
+    print("Method: PatchCore-style nearest-neighbor patch anomaly detection")
+    print("Backbone: ImageNet-pretrained Wide ResNet-50-2")
+    print(f"Outputs: {args.output_csv}, {args.output_json}")
+
+
+if __name__ == "__main__":
+    main()

