+import torch.nn.functional as F
+from PIL import Image
+from torch.utils.data import DataLoader, Dataset
+from torchvision.models import Wide_ResNet50_2_Weights, wide_resnet50_2
+from torchvision.models.feature_extraction import create_feature_extractor
+
+
+IMAGE_EXTENSIONS = {".png", ".jpg", ".jpeg", ".bmp", ".tif", ".tiff", ".webp"}
+
+
+class ImageDataset(Dataset):
+    def __init__(self, root: Path, transform):
+        self.paths = sorted(
+            path for path in root.iterdir()
+            if path.is_file() and path.suffix.lower() in IMAGE_EXTENSIONS
+        )
+        if not self.paths:
+            raise RuntimeError(f"No images found in {root}")
+        self.transform = transform
+
+    def __len__(self):
+        return len(self.paths)
+
+    def __getitem__(self, index):
+        with Image.open(self.paths[index]) as image:
+            return self.transform(image.convert("RGB"))
+
+
+def build_extractor(device: torch.device):
+    weights = Wide_ResNet50_2_Weights.IMAGENET1K_V2
+    backbone = wide_resnet50_2(weights=weights)
+    extractor = create_feature_extractor(
+        backbone, return_nodes={"layer1": "layer1", "layer2": "layer2", "layer3": "layer3"}
+    )
+    return extractor.eval().to(device), weights.transforms()
+
+
+def combine_features(features):
+    target_size = features["layer1"].shape[-2:]
+    layer1 = features["layer1"]
+    layer2 = F.interpolate(
+        features["layer2"], size=target_size, mode="bilinear", align_corners=False
+    )
+    layer3 = F.interpolate(
+        features["layer3"], size=target_size, mode="bilinear", align_corners=False
+    )
+    return torch.cat((layer1, layer2, layer3), dim=1)
+
+
+def smooth_maps(flat_scores, height, width):
+    maps = flat_scores.reshape(-1, 1, height, width)
+    maps = F.interpolate(maps, size=(256, 256), mode="bilinear", align_corners=False)
+    return F.avg_pool2d(maps, kernel_size=15, stride=1, padding=7)
+
+
+def parse_args():
+    parser = argparse.ArgumentParser(description="Fit a PaDiM anomaly model on normal images.")
+    parser.add_argument("--train-dir", type=Path, default=Path("data/train"))
+    parser.add_argument("--model-path", type=Path, default=Path("outputs/model.pt"))
+    parser.add_argument("--batch-size", type=int, default=16)
+    parser.add_argument("--dimensions", type=int, default=100)
+    parser.add_argument("--regularization", type=float, default=1e-2)
+    parser.add_argument("--seed", type=int, default=42)
+    parser.add_argument("--device", default="cuda" if torch.cuda.is_available() else "cpu")
+    return parser.parse_args()
+
+
+def main():
+    args = parse_args()
+    random.seed(args.seed)
+    np.random.seed(args.seed)
+    torch.manual_seed(args.seed)
+    device = torch.device(args.device)
+
+    extractor, transform = build_extractor(device)
+    dataset = ImageDataset(args.train_dir, transform)
+    loader = DataLoader(
+        dataset, batch_size=args.batch_size, shuffle=False, num_workers=2,
+        pin_memory=device.type == "cuda"
+    )
+
+    all_features = []
+    channel_indices = None
+    with torch.inference_mode():
+        for images in loader:
+            combined = combine_features(extractor(images.to(device, non_blocking=True)))
+            if channel_indices is None:
+                if args.dimensions > combined.shape[1]:
+                    raise ValueError("Requested dimensions exceed available feature channels")
+                generator = torch.Generator(device=device).manual_seed(args.seed)
+                channel_indices = torch.randperm(
+                    combined.shape[1], generator=generator, device=device
+                )[:args.dimensions]
+            selected = combined[:, channel_indices].flatten(2)
+            all_features.append(selected.cpu())
+
+    samples = torch.cat(all_features, dim=0).float().to(device)
+    mean = samples.mean(dim=0)
+    centered = samples - mean.unsqueeze(0)
+    covariance = torch.einsum("ndl,nel->lde", centered, centered) / (samples.shape[0] - 1)
+    identity = torch.eye(args.dimensions, device=device).unsqueeze(0)
+    covariance = covariance + args.regularization * identity
+    inverse_covariance = torch.cholesky_inverse(torch.linalg.cholesky(covariance))
+
+    delta = samples - mean.unsqueeze(0)
+    train_scores = torch.sqrt(
+        torch.einsum("ndl,lde,nel->nl", delta, inverse_covariance, delta).clamp_min(0)
+    )
+    feature_height = combined.shape[-2]
+    feature_width = combined.shape[-1]
+    smoothed = smooth_maps(train_scores, feature_height, feature_width)
+    map_scale = torch.quantile(smoothed.flatten(), 0.99).item()
+
+    args.model_path.parent.mkdir(parents=True, exist_ok=True)
+    torch.save(
+        {
+            "method": "PaDiM",
+            "backbone": "wide_resnet50_2",
+            "channel_indices": channel_indices.cpu(),
+            "mean": mean.cpu(),
+            "inverse_covariance": inverse_covariance.cpu(),
+            "feature_size": (feature_height, feature_width),
+            "map_scale": max(map_scale, 1e-6),
+            "seed": args.seed,
+            "train_image_count": len(dataset),
+        },
+        args.model_path,
+    )
+    print(f"Saved model fitted on {len(dataset)} images to {args.model_path}")
+
+
+if __name__ == "__main__":
+    main()

