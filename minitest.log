new file mode 100644
index 0000000000000000000000000000000000000000..c0a006c27bc464917a37bdbcc7039abfebe7964d
--- /dev/null
+++ b/outputs/common.py
@@ -0,0 +1,101 @@
+from pathlib import Path
+
+import numpy as np
+import torch
+import torch.nn.functional as F
+from PIL import Image
+from torch.utils.data import Dataset
+from torchvision.models import Wide_ResNet50_2_Weights, wide_resnet50_2
+
+
+IMAGE_SUFFIXES = {".bmp", ".jpeg", ".jpg", ".png", ".tif", ".tiff", ".webp"}
+IMAGE_SIZE = 256
+FEATURE_SIZE = 64
+
+
+def image_files(root):
+    root = Path(root)
+    files = sorted(
+        path for path in root.rglob("*")
+        if path.is_file() and path.suffix.lower() in IMAGE_SUFFIXES
+    )
+    if not files:
+        raise RuntimeError(f"No images found in {root}")
+    return files
+
+
+class ImageDataset(Dataset):
+    def __init__(self, root):
+        self.files = image_files(root)
+        self.normalize = Wide_ResNet50_2_Weights.IMAGENET1K_V2.transforms()
+
+    def __len__(self):
+        return len(self.files)
+
+    def __getitem__(self, index):
+        path = self.files[index]
+        with Image.open(path) as image:
+            image = image.convert("RGB").resize(
+                (IMAGE_SIZE, IMAGE_SIZE), Image.Resampling.BILINEAR
+            )
+            tensor = self.normalize(image)
+        return tensor, path.name
+
+
+class FeatureExtractor(torch.nn.Module):
+    CHANNELS = (256, 512, 1024)
+
+    def __init__(self, selected_channels):
+        super().__init__()
+        self.backbone = wide_resnet50_2(
+            weights=Wide_ResNet50_2_Weights.IMAGENET1K_V2
+        )
+        self.backbone.eval()
+        for parameter in self.backbone.parameters():
+            parameter.requires_grad_(False)
+
+        selected_channels = torch.as_tensor(selected_channels, dtype=torch.long)
+        offsets = np.cumsum((0,) + self.CHANNELS)
+        for level, (start, end) in enumerate(zip(offsets[:-1], offsets[1:]), 1):
+            indices = selected_channels[
+                (selected_channels >= start) & (selected_channels < end)
+            ] - start
+            self.register_buffer(f"indices_{level}", indices)
+
+    def forward(self, x):
+        model = self.backbone
+        x = model.conv1(x)
+        x = model.bn1(x)
+        x = model.relu(x)
+        x = model.maxpool(x)
+
+        maps = []
+        x = model.layer1(x)
+        maps.append(x.index_select(1, self.indices_1))
+        x = model.layer2(x)
+        maps.append(x.index_select(1, self.indices_2))
+        x = model.layer3(x)
+        maps.append(x.index_select(1, self.indices_3))
+
+        resized = [
+            feature if feature.shape[-2:] == (FEATURE_SIZE, FEATURE_SIZE)
+            else F.interpolate(
+                feature,
+                size=(FEATURE_SIZE, FEATURE_SIZE),
+                mode="bilinear",
+                align_corners=False,
+            )
+            for feature in maps
+        ]
+        return torch.cat(resized, dim=1)
+
+
+def anomaly_map(features, mean, variance):
+    score = ((features - mean) ** 2 / variance).mean(dim=1, keepdim=True).sqrt()
+    return F.avg_pool2d(score, kernel_size=3, stride=1, padding=1)
+
+
+def image_score(score_map, top_fraction=0.01):
+    flat = score_map.flatten(1)
+    count = max(1, int(flat.shape[1] * top_fraction))
+    return flat.topk(count, dim=1).values.mean(dim=1)
