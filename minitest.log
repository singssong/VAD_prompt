+#!/usr/bin/env python3
+"""Fit a one-class positional feature model on normal images."""
+
+import argparse
+import random
+from pathlib import Path
+
+import numpy as np
+import torch
+import torch.nn.functional as F
+from PIL import Image
+from torch import nn
+from torchvision.models import ResNet18_Weights, resnet18
+
+IMAGE_SUFFIXES = {".png", ".jpg", ".jpeg", ".bmp", ".tif", ".tiff", ".webp"}
+
+
+def image_files(root: Path) -> list[Path]:
+    return sorted(
+        p
+        for p in root.rglob("*")
+        if p.is_file()
+        and p.suffix.lower() in IMAGE_SUFFIXES
+        and not any(part.startswith(".") for part in p.relative_to(root).parts)
+    )
+
+
+class FeatureExtractor(nn.Module):
+    def __init__(self) -> None:
+        super().__init__()
+        net = resnet18(weights=ResNet18_Weights.IMAGENET1K_V1)
+        self.stem = nn.Sequential(net.conv1, net.bn1, net.relu, net.maxpool)
+        self.layer1 = net.layer1
+        self.layer2 = net.layer2
+        self.layer3 = net.layer3
+
+    def forward(self, x: torch.Tensor) -> torch.Tensor:
+        x = self.stem(x)
+        f1 = self.layer1(x)
+        f2 = self.layer2(f1)
+        f3 = self.layer3(f2)
+        size = f1.shape[-2:]
+        features = torch.cat(
+            [
+                f1,
+                F.interpolate(f2, size=size, mode="bilinear", align_corners=False),
+                F.interpolate(f3, size=size, mode="bilinear", align_corners=False),
+            ],
+            dim=1,
+        )
+        return F.avg_pool2d(features, kernel_size=3, stride=1, padding=1)
+
+
+def load_batch(paths: list[Path], device: torch.device) -> torch.Tensor:
+    images = []
+    for path in paths:
+        with Image.open(path) as image:
+            array = np.asarray(image.convert("RGB").resize((256, 256)), dtype=np.float32)
+        images.append(torch.from_numpy(array).permute(2, 0, 1) / 255.0)
+    batch = torch.stack(images).to(device)
+    mean = torch.tensor([0.485, 0.456, 0.406], device=device)[None, :, None, None]
+    std = torch.tensor([0.229, 0.224, 0.225], device=device)[None, :, None, None]
+    return (batch - mean) / std
+
+
+def anomaly_maps(
+    features: torch.Tensor, mean: torch.Tensor, variance: torch.Tensor
+) -> torch.Tensor:
+    squared_z = (features - mean).square() / variance
+    maps = torch.sqrt(squared_z.mean(dim=1).clamp_min(0))
+    return F.interpolate(
+        maps[:, None], size=(256, 256), mode="bilinear", align_corners=False
+    )[:, 0]
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--train-dir", type=Path, default=Path("./data/train"))
+    parser.add_argument("--output", type=Path, default=Path("./outputs/model.pt"))
+    parser.add_argument("--batch-size", type=int, default=16)
+    parser.add_argument("--device", default="cuda" if torch.cuda.is_available() else "cpu")
+    args = parser.parse_args()
+
+    random.seed(0)
+    np.random.seed(0)
+    torch.manual_seed(0)
+    paths = image_files(args.train_dir)
+    if not paths:
+        raise RuntimeError(f"No training images found in {args.train_dir}")
+
+    device = torch.device(args.device)
+    extractor = FeatureExtractor().eval().to(device)
+    total = None
+    total_sq = None
+    count = 0
+
+    with torch.inference_mode():
+        for start in range(0, len(paths), args.batch_size):
+            features = extractor(load_batch(paths[start : start + args.batch_size], device))
+            batch_sum = features.double().sum(dim=0)
+            batch_sq = features.double().square().sum(dim=0)
+            total = batch_sum if total is None else total + batch_sum
+            total_sq = batch_sq if total_sq is None else total_sq + batch_sq
+            count += features.shape[0]
+
+        mean = (total / count).float()
+        variance = (total_sq / count - (total / count).square()).float()
+        # A floor prevents nearly constant background features from dominating.
+        channel_floor = torch.quantile(
+            variance.flatten(1), 0.10, dim=1
+        ).clamp_min(1e-4)[:, None, None]
+        variance = torch.maximum(variance, channel_floor)
+
+        calibration_samples = []
+        for start in range(0, len(paths), args.batch_size):
+            features = extractor(load_batch(paths[start : start + args.batch_size], device))
+            maps = anomaly_maps(features, mean, variance)
+            calibration_samples.append(maps.flatten().cpu())
+        calibration = torch.cat(calibration_samples)
+        pixel_low = float(torch.quantile(calibration, 0.95))
+        pixel_high = float(torch.quantile(calibration, 0.999))
+
+    args.output.parent.mkdir(parents=True, exist_ok=True)
+    torch.save(
+        {
+            "mean": mean.cpu(),
+            "variance": variance.cpu(),
+            "pixel_low": pixel_low,
+            "pixel_high": max(pixel_high, pixel_low + 1e-6),
+            "method": "diagonal positional Gaussian multi-scale features",
+            "backbone": "ImageNet ResNet-18",
+            "num_train_images": len(paths),
+        },
+        args.output,
+    )
+    print(f"Trained on {len(paths)} normal images; saved {args.output}")
+
+
+if __name__ == "__main__":
+    main()

