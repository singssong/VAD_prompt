+from __future__ import annotations
+
+import json
+
+import numpy as np
+import torch
+from PIL import Image
+from torch.utils.data import DataLoader
+
+import config
+from anomaly_pipeline import (
+    FeatureExtractor,
+    ImageDataset,
+    extract_features,
+    image_files,
+    normalize_score,
+    score_feature_grid,
+    set_deterministic,
+)
+
+
+def main() -> None:
+    set_deterministic(config.SEED)
+    files = image_files(config.TEST_DIR)
+    if not files:
+        raise RuntimeError(f"No test images found in {config.TEST_DIR}")
+    if not config.MODEL_PATH.exists():
+        raise RuntimeError(f"Run train.py first; missing {config.MODEL_PATH}")
+
+    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
+    checkpoint = torch.load(config.MODEL_PATH, map_location="cpu", weights_only=True)
+    projection = checkpoint["projection"].to(device)
+    memory_bank = checkpoint["memory_bank"].to(device)
+    calibration = checkpoint["calibration"]
+    extractor = FeatureExtractor().eval().to(device)
+    loader = DataLoader(
+        ImageDataset(files),
+        batch_size=config.TEST_BATCH_SIZE,
+        shuffle=False,
+        num_workers=2,
+        pin_memory=device.type == "cuda",
+    )
+
+    config.PIXEL_DIR.mkdir(parents=True, exist_ok=True)
+    scores: dict[str, float] = {}
+    with torch.inference_mode():
+        for images, names in loader:
+            grids = extract_features(extractor, images.to(device), projection)
+            for grid, name in zip(grids, names):
+                anomaly_map, raw_score = score_feature_grid(grid, memory_bank)
+                scores[name] = normalize_score(
+                    raw_score, calibration["image_low"], calibration["image_high"]
+                )
+                normalized_map = (
+                    (anomaly_map.cpu().numpy() - calibration["pixel_low"])
+                    / (calibration["pixel_high"] - calibration["pixel_low"])
+                )
+                pixel_png = np.round(np.clip(normalized_map, 0.0, 1.0) * 255).astype(np.uint8)
+                Image.fromarray(pixel_png, mode="L").save(config.PIXEL_DIR / name)
+
+    with config.SCORES_PATH.open("w", encoding="utf-8") as handle:
+        json.dump(scores, handle, indent=2, sort_keys=True)
+        handle.write("\n")
+    print(f"Scored {len(scores)} images and wrote {config.SCORES_PATH}")
+
+
+if __name__ == "__main__":
+    main()
