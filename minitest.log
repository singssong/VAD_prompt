+#!/usr/bin/env python3
+import json
+from pathlib import Path
+
+import numpy as np
+import torch
+import torch.nn.functional as F
+from PIL import Image
+
+from anomaly_model import (
+    IMAGE_SIZE,
+    FeatureExtractor,
+    aggregate_image_scores,
+    extract_features,
+    image_paths,
+    load_image,
+    normalize_image_score,
+    score_features,
+)
+
+
+# Inference configuration
+ROOT = Path(__file__).resolve().parent.parent
+TEST_DIR = ROOT / "data" / "test_images"
+OUTPUT_DIR = ROOT / "outputs"
+PIXEL_DIR = OUTPUT_DIR / "pixel_scores"
+MODEL_PATH = OUTPUT_DIR / "model.pt"
+SCORES_PATH = OUTPUT_DIR / "image_scores.json"
+DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
+
+
+def save_pixel_map(anomaly_map: torch.Tensor, path: Path, model: dict) -> None:
+    resized = F.interpolate(
+        anomaly_map[None, None],
+        size=(IMAGE_SIZE, IMAGE_SIZE),
+        mode="bilinear",
+        align_corners=False,
+    )[0, 0]
+    low = model["pixel_low"].to(resized.device)
+    high = model["pixel_high"].to(resized.device)
+    normalized = ((resized - low) / (high - low).clamp_min(1e-6)).clamp(0, 1)
+    pixels = (normalized.cpu().numpy() * 255.0).round().astype(np.uint8)
+    Image.fromarray(pixels, mode="L").save(path)
+
+
+def score_image(
+    extractor: FeatureExtractor,
+    path: Path,
+    model: dict,
+) -> tuple[float, torch.Tensor]:
+    image = load_image(path).unsqueeze(0).to(DEVICE)
+    features = extract_features(extractor, image)
+    anomaly_map = score_features(
+        features,
+        model["mean"].to(DEVICE),
+        model["variance"].to(DEVICE),
+    )[0]
+    raw_score = aggregate_image_scores(anomaly_map.unsqueeze(0))[0]
+    score = normalize_image_score(raw_score, model)
+    return float(score.cpu()), anomaly_map
+
+
+def main() -> None:
+    paths = image_paths(TEST_DIR)
+    if not paths:
+        raise RuntimeError(f"No test images found in {TEST_DIR}")
+    if not MODEL_PATH.exists():
+        raise RuntimeError(f"Missing {MODEL_PATH}; run train.py first")
+
+    PIXEL_DIR.mkdir(parents=True, exist_ok=True)
+    model = torch.load(MODEL_PATH, map_location="cpu", weights_only=True)
+    extractor = FeatureExtractor().to(DEVICE)
+    scores = {}
+
+    for path in paths:
+        score, anomaly_map = score_image(extractor, path, model)
+        scores[path.name] = score
+        save_pixel_map(anomaly_map, PIXEL_DIR / path.name, model)
+
+    with SCORES_PATH.open("w", encoding="utf-8") as handle:
+        json.dump(scores, handle, indent=2, sort_keys=True)
+        handle.write("\n")
+    print(f"Scored {len(scores)} images and wrote results to {OUTPUT_DIR}")
+
+
+if __name__ == "__main__":
+    main()
+
