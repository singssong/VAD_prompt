+#!/usr/bin/env python3
+from pathlib import Path
+
+import torch
+
+from anomaly_model import (
+    FeatureExtractor,
+    aggregate_image_scores,
+    extract_features,
+    fit_normal_model,
+    image_paths,
+    load_image,
+    score_features,
+)
+
+
+# Training configuration
+TRAIN_DIR = Path(__file__).resolve().parent.parent / "data" / "train"
+MODEL_PATH = Path(__file__).resolve().parent / "model.pt"
+BATCH_SIZE = 8
+DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
+
+
+def calibrate_scores(
+    extractor: FeatureExtractor,
+    paths: list[Path],
+    model: dict,
+) -> dict:
+    mean = model["mean"].to(DEVICE)
+    variance = model["variance"].to(DEVICE)
+    image_scores = []
+    pixel_scores = []
+
+    for start in range(0, len(paths), BATCH_SIZE):
+        batch = torch.stack([load_image(path) for path in paths[start:start + BATCH_SIZE]])
+        features = extract_features(extractor, batch.to(DEVICE))
+        maps = score_features(features, mean, variance)
+        image_scores.append(aggregate_image_scores(maps).cpu())
+        pixel_scores.append(maps.flatten().cpu())
+
+    image_scores = torch.cat(image_scores)
+    pixel_scores = torch.cat(pixel_scores)
+    median = image_scores.median()
+    mad = (image_scores - median).abs().median()
+    model["score_median"] = median
+    model["score_scale"] = (1.4826 * mad).clamp_min(1e-6)
+    model["pixel_low"] = torch.quantile(pixel_scores, 0.95)
+    model["pixel_high"] = torch.quantile(pixel_scores, 0.999)
+    return model
+
+
+def main() -> None:
+    paths = image_paths(TRAIN_DIR)
+    if not paths:
