+        if not self.paths:
+            raise RuntimeError(f"No images found in {root}")
+        self.transform = transform
+
+    def __len__(self) -> int:
+        return len(self.paths)
+
+    def __getitem__(self, index: int) -> tuple[Tensor, str]:
+        path = self.paths[index]
+        with Image.open(path) as image:
+            tensor = self.transform(image.convert("RGB"))
+        return tensor, path.name
+
+
+class WideResNetFeatures(nn.Module):
+    """ImageNet features from the first three residual stages."""
+
+    def __init__(self) -> None:
+        super().__init__()
+        model = wide_resnet50_2(weights=Wide_ResNet50_2_Weights.IMAGENET1K_V2)
+        self.stem = nn.Sequential(model.conv1, model.bn1, model.relu, model.maxpool)
+        self.layer1 = model.layer1
+        self.layer2 = model.layer2
+        self.layer3 = model.layer3
+
+    def forward(self, images: Tensor) -> Tensor:
+        x = self.stem(images)
+        layer1 = self.layer1(x)
+        layer2 = self.layer2(layer1)
+        layer3 = self.layer3(layer2)
+
+        target_size = layer3.shape[-2:]
+        layer1 = F.adaptive_avg_pool2d(layer1, target_size)
+        layer2 = F.adaptive_avg_pool2d(layer2, target_size)
+        return torch.cat((layer1, layer2, layer3), dim=1)
+
+
+def make_projection(input_dim: int, output_dim: int, device: torch.device) -> Tensor:
+    generator = torch.Generator(device="cpu").manual_seed(17)
+    projection = torch.randn(input_dim, output_dim, generator=generator)
+    projection /= math.sqrt(output_dim)
+    return projection.to(device)
+
+
+@torch.inference_mode()
+def extract_features(
+    model: nn.Module,
+    loader: DataLoader,
+    device: torch.device,
+    projection: Tensor | None = None,
+) -> tuple[Tensor, list[str], Tensor]:
+    feature_batches: list[Tensor] = []
+    names: list[str] = []
+
+    for images, batch_names in loader:
+        features = model(images.to(device, non_blocking=True))
+        features = F.avg_pool2d(features, kernel_size=3, stride=1, padding=1)
+        features = features.permute(0, 2, 3, 1).contiguous()
+
+        if projection is None:
+            projection = make_projection(features.shape[-1], 384, device)
+        features = features @ projection
+        features = F.normalize(features, dim=-1)
+        feature_batches.append(features.cpu())
+        names.extend(batch_names)
+
+    assert projection is not None
+    return torch.cat(feature_batches), names, projection
+
+
+def shifted_bank(bank: Tensor, dy: int, dx: int) -> Tensor:
+    """Shift a feature bank without wrapping values across image boundaries."""
+    _, height, width, _ = bank.shape
+    y_source = torch.arange(height, device=bank.device).sub(dy).clamp(0, height - 1)
+    x_source = torch.arange(width, device=bank.device).sub(dx).clamp(0, width - 1)
+    return bank.index_select(1, y_source).index_select(2, x_source)
+
+
+@torch.inference_mode()
+def patch_anomaly_maps(
+    query: Tensor,
+    bank: Tensor,
+    query_indices: Tensor | None = None,
+) -> Tensor:
+    """Return one nearest-normal cosine distance per spatial patch."""
+    best_similarity = torch.full(
+        query.shape[:-1], -1.0, dtype=query.dtype, device=query.device
+    )
+
+    # A cross-shaped neighborhood permits modest registration error while
+    # keeping each patch tied to the corresponding part of the bottle.
+    for dy, dx in ((0, 0), (-1, 0), (1, 0), (0, -1), (0, 1)):
+        candidates = shifted_bank(bank, dy, dx)
+        similarities = torch.einsum("bhwd,nhwd->bnhw", query, candidates)
+        if query_indices is not None and dy == 0 and dx == 0:
+            batch_ids = torch.arange(query.shape[0], device=query.device)
+            similarities[batch_ids, query_indices] = -1.0
+        best_similarity = torch.maximum(best_similarity, similarities.amax(dim=1))
+
+    return 1.0 - best_similarity
+
+
+def image_scores(patch_maps: Tensor) -> Tensor:
+    flat = patch_maps.flatten(1)
+    top_k = max(1, math.ceil(flat.shape[1] * 0.02))
+    return flat.topk(top_k, dim=1).values.mean(dim=1)
+
+
+@torch.inference_mode()
+def score_feature_set(
+    features: Tensor,
+    bank: Tensor,
+    device: torch.device,
+    batch_size: int,
+    leave_one_out: bool = False,
+) -> Tensor:
+    outputs: list[Tensor] = []
+    for start in range(0, len(features), batch_size):
+        end = min(start + batch_size, len(features))
+        query = features[start:end].to(device)
+        indices = (
+            torch.arange(start, end, device=device) if leave_one_out else None
+        )
+        outputs.append(image_scores(patch_anomaly_maps(query, bank, indices)).cpu())
+    return torch.cat(outputs)
+
+
+def robust_standardize(test_scores: Tensor, reference_scores: Tensor) -> Tensor:
+    median = reference_scores.median()
+    mad = (reference_scores - median).abs().median().clamp_min(1e-6)
+    # The factor makes MAD comparable to standard deviation for normal data.
+    return (test_scores - median) / (1.4826 * mad)
+
+
+def write_scores(
+    output_path: Path,
+    names: list[str],
+    raw_scores: Tensor,
+    standardized_scores: Tensor,
+) -> None:
+    with output_path.open("w", newline="") as handle:
+        writer = csv.writer(handle)
+        writer.writerow(("filename", "anomaly_score", "raw_patchcore_score"))
+        for name, score, raw_score in zip(names, standardized_scores, raw_scores):
+            writer.writerow((name, f"{score.item():.8f}", f"{raw_score.item():.8f}"))
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--train-dir", type=Path, default=Path("data/train"))
+    parser.add_argument("--test-dir", type=Path, default=Path("data/test_images"))
+    parser.add_argument("--output", type=Path, default=Path("anomaly_scores.csv"))
+    parser.add_argument("--batch-size", type=int, default=16)
+    return parser.parse_args()
+
+
+def main() -> None:
+    args = parse_args()
+    torch.manual_seed(17)
+    if torch.cuda.is_available():
+        device = torch.device("cuda")
+        torch.backends.cudnn.benchmark = True
+    else:
+        device = torch.device("cpu")
+
+    weights = Wide_ResNet50_2_Weights.IMAGENET1K_V2
+    transform = weights.transforms(crop_size=256, resize_size=256)
+    train_dataset = ImageDataset(args.train_dir, transform)
+    test_dataset = ImageDataset(args.test_dir, transform)
+    loader_args = {
+        "batch_size": args.batch_size,
+        "num_workers": 4,
+        "pin_memory": device.type == "cuda",
+    }
+    train_loader = DataLoader(train_dataset, shuffle=False, **loader_args)
+    test_loader = DataLoader(test_dataset, shuffle=False, **loader_args)
+
+    model = WideResNetFeatures().eval().to(device)
+    train_features, train_names, projection = extract_features(
+        model, train_loader, device
+    )
+    test_features, test_names, _ = extract_features(
+        model, test_loader, device, projection
+    )
+    del model
+
+    bank = train_features.to(device)
+    train_scores = score_feature_set(
+        train_features, bank, device, args.batch_size, leave_one_out=True
+    )
+    test_scores = score_feature_set(
+        test_features, bank, device, args.batch_size, leave_one_out=False
+    )
+    standardized_scores = robust_standardize(test_scores, train_scores)
+    write_scores(args.output, test_names, test_scores, standardized_scores)
+
+    print(f"Reference images: {len(train_names)}")
+    print(f"Scored images: {len(test_names)}")
+    print(f"Output: {args.output}")
+    print("Method: location-aware multi-scale PatchCore (cosine nearest neighbor)")
+    print("Backbone: ImageNet Wide ResNet-50-2")
+
+
+if __name__ == "__main__":
+    main()

